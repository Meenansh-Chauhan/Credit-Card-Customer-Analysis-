    <worksheet name='WS11 - Revenue by Age Group'>
      <layout-options>
        <title>
          <formatted-text>
            <run fontcolor='#e6e8ed' fontname='Segoe UI Semibold'>Revenue by Age Group</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='Clean_Transaction.csv+ (Multiple Connections)' name='federated.0hywem01uf6drv11w9j6w03orhel' />
          </datasources>
          <datasource-dependencies datasource='federated.0hywem01uf6drv11w9j6w03orhel'>
            <column caption='Age Group' datatype='string' name='[Calculation_1732577462046721]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [age] &gt;= 21 AND [age] &lt;= 29 THEN &quot;21–29&quot;&#13;&#10;&#13;&#10;ELSEIF [age] &gt;= 30 AND [age] &lt;= 39 THEN &quot;30–39&quot;&#13;&#10;&#13;&#10;ELSEIF [age] &gt;= 40 AND [age] &lt;= 49 THEN &quot;40–49&quot;&#13;&#10;&#13;&#10;ELSEIF [age] &gt;= 50 AND [age] &lt;= 59 THEN &quot;50–59&quot;&#13;&#10;&#13;&#10;ELSE &quot;60+&quot;&#13;&#10;&#13;&#10;END' />
            </column>
            <column caption='Total Spending' datatype='real' name='[Total_Spending]' role='measure' type='quantitative' />
