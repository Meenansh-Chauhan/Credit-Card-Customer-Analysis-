          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Highlight Category' datatype='string' name='[Calculation_0903820000235527]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF RANK(SUM([amount])) = 1 THEN&#13;&#10;&quot;Highest Revenue&quot;&#13;&#10;ELSE&#13;&#10;&quot;Other&quot;&#13;&#10;END'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Age Group' datatype='string' name='[Calculation_1732577462046721]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [age] &gt;= 21 AND [age] &lt;= 29 THEN &quot;21–29&quot;&#13;&#10;&#13;&#10;ELSEIF [age] &gt;= 30 AND [age] &lt;= 39 THEN &quot;30–39&quot;&#13;&#10;&#13;&#10;ELSEIF [age] &gt;= 40 AND [age] &lt;= 49 THEN &quot;40–49&quot;&#13;&#10;&#13;&#10;ELSEIF [age] &gt;= 50 AND [age] &lt;= 59 THEN &quot;50–59&quot;&#13;&#10;&#13;&#10;ELSE &quot;60+&quot;&#13;&#10;&#13;&#10;END' />
      </column>
      <column caption='One' datatype='integer' name='[Calculation_2598717403115520]' role='measure' type='quantitative'>
