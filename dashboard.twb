      <column caption='Average Transaction' datatype='real' name='[Average_Transaction]' role='measure' type='quantitative' />
      <column caption='Total Revenue' datatype='real' default-format='c&quot;₹ &quot;#,##0.00;&quot;₹ &quot;-#,##0.00' name='[Calculation_0903819927117824]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([amount])' />
      </column>
      <column caption='Sum Transactions' datatype='integer' default-format='n#,##0;-#,##0' name='[Calculation_0903819927269377]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT([id])' />
      </column>
      <column caption='Total Customers' datatype='integer' default-format='n#,##0;-#,##0' name='[Calculation_0903819928023042]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD([customer_id])' />
      </column>
      <column caption='Avg Transaction' datatype='real' default-format='c&quot;₹ &quot;#,##0.00;&quot;₹ &quot;-#,##0.00' name='[Calculation_0903819928141827]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([amount])' />
      </column>
      <column caption='Revenue (M)' datatype='real' default-format='n&quot;₹&quot;#,##0.00;-&quot;₹&quot;#,##0.00' name='[Calculation_0903819928674308]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([amount]) / 1000000' />
      </column>
      <column caption='Revenue Category Rank' datatype='integer' name='[Calculation_0903819933978630]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='RANK(SUM([amount]))'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Highlight Category' datatype='string' name='[Calculation_0903820000235527]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF RANK(SUM([amount])) = 1 THEN&#13;&#10;&quot;Highest Revenue&quot;&#13;&#10;ELSE&#13;&#10;&quot;Other&quot;&#13;&#10;END'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='One' datatype='integer' name='[Calculation_2598717403115520]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='1' />
      </column>
